
@inject NavigationManager Navigate 

<div class="list-group-item d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
        @if (Habit.IsPaused == true)
        {
            <input type="checkbox" disabled checked="@Habit.IsCompletedToday"/>
            <span class="@TitleClass @TitleClass">@Habit.Title</span>
            <span class="badge bg-warning text-dark">Paused habit</span>
        }
        else
        {
            <input type="checkbox" checked="@Habit.IsCompletedToday"
                   @onchange="OnChanged" />

            <span class="@TitleClass">@Habit.Title</span>
        }
        
    </div>

    <div class="d-flex justify-content-between gap-2">
        <button class="btn btn-sm btn-outline-primary"
                @onclick="GoToDetails">
            <i class="bi bi-pencil-square">View</i>
        </button>
    </div>
</div>

@code {
    [Parameter] public HabitTodayDTO Habit { get; set; } = default!;
    [Parameter] public EventCallback<HabitTodayDTO> OnToggleCompleted { get; set; }

    private string TitleClass =>
        Habit.IsCompletedToday || Habit.IsPaused ? "text-decoration-line-through text-muted" : "";


    private async Task OnChanged(ChangeEventArgs e)
    {
        await OnToggleCompleted.InvokeAsync(Habit);
    }

    private void GoToDetails()
    {
        Navigate.NavigateTo($"/habits/{Habit.Id}");
    }
}