@using HabitTracker.Application.DTOs



<div class="heatmap-container">

    <div class="heatmap-grid-wrapper">

        <div class="heatmap-days">
            <div>Mon</div>
            <div>Tue</div>
            <div>Wed</div>
            <div>Thu</div>
            <div>Fri</div>
            <div>Sat</div>
            <div>Sun</div>
        </div>

        <div class="heatmap-grid">
            @foreach (var week in Weeks)
            {
                @foreach (var day in week)
                {
                    <div class="heatmap-cell @GetIntensityClass(day)"></div>
                }
            }
        </div>

    </div>

</div>

@code {
    [Parameter]
    public List<DailyActivityDTO> Data { get; set; } = new();

    [Parameter] public DateOnly StartDate { get; set; }
    [Parameter] public DateOnly EndDate { get; set; }

    public List<List<DailyActivityDTO>> Weeks { get; set; } = new();

    protected override void OnParametersSet()
    {
        if (StartDate == default ||
        EndDate == default ||
        EndDate < StartDate)
            return;

        BuildWeeks();
    }

    private void BuildWeeks()
    {
        Weeks.Clear();

        var ordered = Data.OrderBy(d => d.Date).ToList();

        var startDate = StartDate;
        var endDate = EndDate;

        var firstWeekStart = startDate.AddDays(-(int)startDate.DayOfWeek);
        var current = firstWeekStart;

        while (current <= endDate)
        {
            var week = new List<DailyActivityDTO>();

            for (int i = 0; i < 7; i++)
            {
                var existing = ordered.FirstOrDefault(d => d.Date == current);

                week.Add(existing ?? new DailyActivityDTO
                {
                    Date = current,
                    CompletionsCount = 0
                });

                current = current.AddDays(1);
            }

            Weeks.Add(week);
        }
    }

    private string GetIntensityClass(DailyActivityDTO day)
    {
        if (day.Date > DateOnly.FromDateTime(DateTime.Today))
            return "future-day";

        if (day.CompletionsCount == 0)
            return "level-0";

        if (day.CompletionsCount <= 2)
            return "level-1";

        if (day.CompletionsCount <= 5)
            return "level-2";

        return "level-3";
    }
}
